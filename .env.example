APP_NAME=MoCU-PRMS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://prms.example.ac.tz

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=prms
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.ac.tz"
MAIL_FROM_NAME="${APP_NAME}"

PRMS_HELP_DESK_LABEL="ICT Help Desk"
PRMS_HELP_DESK_EMAIL=icthelpdesk@mocu.ac.tz

# Ollama — optional; disable on production unless the service is available
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=mistral
OLLAMA_TIMEOUT=120
OLLAMA_SIMILARITY_TEXT_MIN=12
OLLAMA_SIMILARITY_MAX_CANDIDATES=8
OLLAMA_SIMILARITY_STORE_THRESHOLD=35
OLLAMA_SIMILARITY_ALERT_THRESHOLD=65

# ONLYOFFICE — optional online Word editor (Docker: docker compose -f docker-compose.onlyoffice.yml up -d)
# DOCUMENT_SERVER_URL — URL the browser loads (api.js + editor iframe). Example: http://YOUR_SERVER:8080
# STORAGE_URL — URL the Document Server uses to download/save files FROM Laravel (must be reachable inside Docker, NOT 127.0.0.1 when browsing remotely).
#   Local XAMPP + Docker Desktop: ONLYOFFICE_STORAGE_URL=http://host.docker.internal
#   Linux server (Laravel on host): ONLYOFFICE_STORAGE_URL=http://172.17.0.1 or http://YOUR_SERVER_IP
# JWT must match docker-compose.onlyoffice.yml (JWT_ENABLED=false there → set ONLYOFFICE_JWT_ENABLED=false below).
ONLYOFFICE_DOCUMENT_SERVER_URL=http://127.0.0.1:8080
ONLYOFFICE_STORAGE_URL=http://host.docker.internal
ONLYOFFICE_JWT_SECRET=
ONLYOFFICE_JWT_ENABLED=false
ONLYOFFICE_MAX_UPLOAD_KB=20480

# SMS — optional; logs only when disabled
PRMS_SMS_ENABLED=false
PRMS_SMS_DRIVER=log
PRMS_SMS_HTTP_URL=
PRMS_SMS_HTTP_TOKEN=
PRMS_SMS_SENDER_ID=MoCU-PRMS

# Path to mysqldump for `php artisan prms:backup` (Windows example)
# MYSQLDUMP_PATH=C:\xampp\mysql\bin\mysqldump.exe
# MYSQL_PATH=C:\xampp\mysql\bin\mysql.exe
